menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default y

if LED_SUBSYSTEM

# --- Homework requirement: simple int period (range 100-2000) ---
config APP_HEARTBEAT_PERIOD_MS
    int "Heartbeat LED blink period (ms)"
    default 500
    range 100 2000
    help
      Controls the heartbeat LED blink duration in milliseconds.
      Change this in menuconfig and rebuild to see blink speed change.

# --- Choice-based blink time (preset options) ---
choice BLINK_SLEEP_TIME
    prompt "LED blink sleep time (preset)"
    default BLINK_SLEEP_TIME_1000MS

config BLINK_SLEEP_TIME_250MS
    bool "250ms (fast)"
config BLINK_SLEEP_TIME_500MS
    bool "500ms (medium-fast)"
config BLINK_SLEEP_TIME_1000MS
    bool "1s (medium)"
config BLINK_SLEEP_TIME_2000MS
    bool "2s (slow)"

endchoice

config BLINK_SLEEP_TIME_MS
    int
    default 250  if BLINK_SLEEP_TIME_250MS
    default 500  if BLINK_SLEEP_TIME_500MS
    default 1000 if BLINK_SLEEP_TIME_1000MS
    default 2000 if BLINK_SLEEP_TIME_2000MS
    default 0

menuconfig ADVANCED_LED_SETTINGS
    bool "Advanced LED settings"
    default n

if ADVANCED_LED_SETTINGS

config LED_BRIGHTNESS
    int "LED brightness (0-100)"
    range 0 100
    default 100

config LED_FADE_DURATION
    int "LED fade duration (ms)"
    range 0 5000
    default 500

menu "Expert settings"
    visible if ADVANCED_LED_SETTINGS

config LED_DEBUG
    bool "Enable LED debugging"
    default n

config CUSTOM_BLINK_PATTERN
    bool "Custom blink pattern"
    default n

endmenu

endif # ADVANCED_LED_SETTINGS

endif # LED_SUBSYSTEM

source "Kconfig.zephyr"
